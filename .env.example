PORT=3000
CORS_ORIGIN=*

# Your Lsky Pro site, without trailing slash.
LSKY_BASE_URL=https://your-lsky-domain.com

# Auth mode:
# - auto: prefer /api/v1 token auth, fallback to web session
# - session: Lsky Pro 2.1 style deployment, log in with web form and use /user/albums
# - api: use API token auth only
LSKY_AUTH_MODE=auto

# API mode config
LSKY_API_PREFIX=/api/v1
LSKY_API_TOKEN_PATH=/tokens
LSKY_LOGIN_PATH=/login
LSKY_PRIVATE_ALBUMS_PATH=/user/albums
LSKY_PRIVATE_IMAGES_PATH=/user/images
LSKY_API_PRIVATE_ALBUMS_PATH=/albums
LSKY_API_PRIVATE_IMAGES_PATH=/images
LSKY_PUBLIC_USER_ALBUMS_PATH=/explore/users/{username}/albums

# Preferred for API mode: use a long-lived personal access token from Lsky.
LSKY_ACCESS_TOKEN=

# Session mode config. Works for your Lsky Pro 2.1 instance:
# login form: /login
# album list: /user/albums
LSKY_LOGIN_PAGE_PATH=/login
LSKY_SESSION_LOGIN_PATH=/login
LSKY_LOGIN_FIELD=email
LSKY_API_TOKEN_FIELD=email
LSKY_USERNAME=your-email@example.com
LSKY_PASSWORD=your-password
LSKY_REMEMBER=true

# Optional API mode login fields
LSKY_LOGIN_TYPE=username
LSKY_LOGIN_TOKEN=

# Request timeout in milliseconds.
REQUEST_TIMEOUT_MS=10000
